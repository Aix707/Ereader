{
  "name": "ereader",
  "version": "1.1.0",
  "private": true,
  "author": "Aix707",
  "description": "A local Windows reader for novels, manga, PDF, EPUB, TXT, and image folders.",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "doctor": "electron scripts/doctor.cjs",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "clean:release": "node scripts/clean-release.cjs",
    "package:win": "npm run clean:release && set ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/&& set ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/&& npm run build && electron-builder --win nsis --x64 --publish never --config.npmRebuild=false",
    "release:win": "npm run clean:release && electron-builder --win nsis --x64 --publish never"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.100",
    "@zip.js/zip.js": "^2.8.26",
    "better-sqlite3": "^12.11.1",
    "chardet": "^2.1.0",
    "fast-xml-parser": "^5.9.2",
    "iconv-lite": "^0.6.3",
    "lucide-react": "^0.468.0",
    "node-html-parser": "^7.1.0",
    "pdfjs-dist": "^4.9.155",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sanitize-html": "^2.17.5",
    "sharp": "^0.35.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^40.10.4",
    "electron-builder": "^26.15.3",
    "typescript": "^5.7.2",
    "vite": "^6.0.6"
  },
  "build": {
    "appId": "com.aix707.ereader",
    "productName": "Ereader",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/app-icon.png",
      "artifactName": "${productName}-${version}-Setup-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Ereader"
    }
  }
}
